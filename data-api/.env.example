# Copy to .env (gitignored) and fill in real values on the on-prem host. Never commit .env.

# --- SQL Server (local to this machine, same box as this service) ---
# DB_NAME is our own writable DB (dim_report / app_user / comment_entry).
DB_SERVER=
DB_PORT=1433
DB_NAME=P26AICatalyst_Work
DB_USER=
DB_PASSWORD=
DB_TRUST_SERVER_CERTIFICATE=true

# --- DWH's read-only product master (same SQL Server instance, different DB) ---
# Cross-database read for /product/resolve — needs SELECT on view_dim_product here,
# separate from the write access to DB_NAME above.
PRODUCT_DB_NAME=P26AICatalyst

# --- Shared secret with the Next.js app ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match DATA_API_KEY in the Next.js app's env vars.
DATA_API_KEY=

# --- Local port (the Next.js app calls http://localhost:4000) ---
PORT=4000

# Copy to .env (gitignored) and fill in real values on the on-prem host. Never commit .env.

# --- SQL Server (local to this machine's network, no VPN needed here) ---
DB_SERVER=
DB_PORT=1433
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_TRUST_SERVER_CERTIFICATE=true

# --- Shared secret with the Render-hosted Next.js app ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match DATA_API_KEY in the Next.js app's env vars.
DATA_API_KEY=

# --- Local port (Tailscale Funnel points at this) ---
PORT=4000

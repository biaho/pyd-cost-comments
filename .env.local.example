# Copy to .env.local (gitignored) and fill in real values. Never commit .env.local.

# --- On-prem SQL Server (PYD domain, reached via VPN during local dev) ---
DB_SERVER=
DB_PORT=1433
DB_NAME=
DB_USER=
DB_PASSWORD=
# true only if the server has a self-signed/internal CA cert during local-first testing
DB_TRUST_SERVER_CERTIFICATE=true

# --- Entra ID (single-tenant App Registration, MSAL) ---
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=
NEXT_PUBLIC_AZURE_AD_TENANT_ID=
NEXT_PUBLIC_AZURE_AD_REDIRECT_URI=http://localhost:3000

# --- ElevenLabs (speech-to-text) ---
ELEVENLABS_API_KEY=

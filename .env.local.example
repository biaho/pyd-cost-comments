# Copy to .env.local (gitignored) and fill in real values. Never commit .env.local.

# --- On-prem Data API (see ./data-api/) ---
# The app never connects to SQL Server directly -- it calls the Data API,
# which runs alongside it on the same on-prem server, over localhost.
DATA_API_URL=http://localhost:4000
DATA_API_KEY=

# --- On-prem SQL Server (PYD domain, reached via VPN) ---
# Only used by scripts/*.ts (test-db-local, run-migration, check-usage-log) for
# local dev tooling -- the deployed app itself never reads these, see DATA_API_URL above.
DB_SERVER=
DB_PORT=1433
DB_NAME=
DB_USER=
DB_PASSWORD=
# true only if the server has a self-signed/internal CA cert during local-first testing
DB_TRUST_SERVER_CERTIFICATE=true

# --- Admin usage dashboard ---
# No verified user identity anymore (see src/lib/auth.ts, src/lib/admin.ts) --
# access to /admin/usage is gated on this shared secret, appended as ?key=
# to the URL and handed out of band. Stopgap, not a final design.
ADMIN_ACCESS_KEY=

# --- DWH link-validation tool (/link-test) ---
# Off by default (hard 404). Set to "true" + restart to let DWH click-test
# TARGIT deep links against the real DB without touching the real app.
ENABLE_LINK_TEST_MODE=false

# --- ElevenLabs (speech-to-text) ---
ELEVENLABS_API_KEY=
